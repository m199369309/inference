{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "集群概览",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Supervisor Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "xinference:supervisor_uptime_seconds{cluster=~\"$cluster\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Workers Online",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "xinference:workers_total{cluster=~\"$cluster\"}",
          "legendFormat": "Workers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Models by Type",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "xinference:models_loaded_total{cluster=~\"$cluster\"}",
          "legendFormat": "{{model_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Worker 资源",
      "type": "row"
    },
    {
      "id": 4,
      "title": "GPU 利用率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xinference:worker_gpu_utilization_percent{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} GPU{{gpu_index}} ({{gpu_name}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "GPU 显存使用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xinference:worker_gpu_memory_used_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} GPU{{gpu_index}} Used",
          "refId": "A"
        },
        {
          "expr": "xinference:worker_gpu_memory_total_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} GPU{{gpu_index}} Total",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU 利用率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xinference:worker_cpu_utilization{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "内存使用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xinference:worker_memory_used_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} Used",
          "refId": "A"
        },
        {
          "expr": "xinference:worker_memory_total_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} Total",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "模型状态与 GPU 绑定",
      "type": "row"
    },
    {
      "id": 8,
      "title": "模型部署全景",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "model_name", "desc": false }]
      },
      "targets": [
        {
          "expr": "xinference:model_info{cluster=~\"$cluster\"} == 1",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "model_name": "Model Name",
              "model_type": "Type",
              "model_uid": "UID",
              "worker_address": "Worker",
              "replica_on_worker": "Replicas (Worker)",
              "replica_total": "Replicas (Total)"
            }
          }
        }
      ]
    },
    {
      "id": 9,
      "title": "GPU 绑定关系",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "worker_address", "desc": false }]
      },
      "targets": [
        {
          "expr": "xinference:model_gpu_binding{cluster=~\"$cluster\"} == 1",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "model_name": "Model Name",
              "model_type": "Type",
              "model_uid": "UID",
              "worker_address": "Worker",
              "gpu_index": "GPU",
              "replica_index": "Replica"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "模型服务质量",
      "type": "row"
    },
    {
      "id": 10,
      "title": "QPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(xinference:model_request_total{cluster=~\"$cluster\", model_name=~\"$model_name\"}[5m])) by (model_name)",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "错误率 (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(xinference:model_request_errors_total{cluster=~\"$cluster\", model_name=~\"$model_name\"}[5m]) / rate(xinference:model_request_total{cluster=~\"$cluster\", model_name=~\"$model_name\"}[5m]) * 100",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "P95 延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(xinference:model_request_duration_seconds_bucket{cluster=~\"$cluster\", model_name=~\"$model_name\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(xinference:model_request_duration_seconds_bucket{cluster=~\"$cluster\", model_name=~\"$model_name\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} P50",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "title": "并发请求 / 限制",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xinference:model_serve_count{cluster=~\"$cluster\", model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}} serving",
          "refId": "A"
        },
        {
          "expr": "xinference:model_request_limit{cluster=~\"$cluster\", model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}} limit",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "id": 104,
      "title": "LLM 专属",
      "type": "row"
    },
    {
      "id": 14,
      "title": "生成吞吐量",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xinference:generate_tokens_per_s{cluster=~\"$cluster\", model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "首 Token 延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xinference:time_to_first_token_ms{cluster=~\"$cluster\", model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "id": 105,
      "title": "主机资源（node_exporter）",
      "type": "row"
    },
    {
      "id": 16,
      "title": "磁盘 I/O 吞吐",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 58 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}[5m])",
          "legendFormat": "{{worker_address}} Read",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}[5m])",
          "legendFormat": "{{worker_address}} Write",
          "refId": "B"
        }
      ]
    },
    {
      "id": 17,
      "title": "磁盘空间使用率",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 58 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "1 - node_filesystem_avail_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\", mountpoint=\"/\"} / node_filesystem_size_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\", mountpoint=\"/\"}",
          "legendFormat": "{{worker_address}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "title": "网络流量",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 66 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{cluster=~\"$cluster\", worker_address=~\"$worker_address\", device!=\"lo\"}[5m])",
          "legendFormat": "{{worker_address}} {{device}} RX",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{cluster=~\"$cluster\", worker_address=~\"$worker_address\", device!=\"lo\"}[5m])",
          "legendFormat": "{{worker_address}} {{device}} TX",
          "refId": "B"
        }
      ]
    },
    {
      "id": 19,
      "title": "系统负载",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 66 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "node_load1{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} load1",
          "refId": "A"
        },
        {
          "expr": "node_load5{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} load5",
          "refId": "B"
        },
        {
          "expr": "node_load15{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} load15",
          "refId": "C"
        }
      ]
    },
    {
      "id": 20,
      "title": "Swap 使用量",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 74 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1073741824 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "node_memory_SwapTotal_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\"} - node_memory_SwapFree_bytes{cluster=~\"$cluster\", worker_address=~\"$worker_address\"}",
          "legendFormat": "{{worker_address}} Swap Used",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["xinference", "ai", "gpu"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(xinference:workers_total, cluster)",
        "hide": 0,
        "includeAll": true,
        "label": "集群",
        "multi": false,
        "name": "cluster",
        "options": [],
        "query": { "query": "label_values(xinference:workers_total, cluster)", "refId": "cluster" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(xinference:worker_cpu_utilization{cluster=~\"$cluster\"}, worker_address)",
        "hide": 0,
        "includeAll": true,
        "label": "Worker",
        "multi": true,
